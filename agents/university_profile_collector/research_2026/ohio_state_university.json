  "strategic_profile": {
    "executive_summary": "The Ohio State University is a massive, flagship public research university offering over 200 majors and a highly spirited campus culture. It operates a pre-major system for selective programs and heavily prioritizes in-state enrollment.",
    "market_position": "Flagship Public University / Public Ivy",
    "admissions_philosophy": "Holistic",
    "us_news_rank": 41,
    "analyst_takeaways": [
      {
        "category": "Selectivity",
        "insight": "Out-of-state acceptance rates (27.2%) are significantly lower than in-state rates (63.9%).",
        "implication": "Non-residents face a highly competitive admissions environment akin to selective private institutions."
      },
      {
        "category": "Academic",
        "insight": "Impacted majors like Business and Computer Science utilize a pre-major track with stringent internal GPA requirements.",
        "implication": "Initial admission does not guarantee entry into desired majors; students must maintain strong academic performance in rigorous early coursework."
      }
    ],
    "campus_dynamics": {
      "social_environment": "Vibrant and massive student body with 1,000+ organizations, 65 fraternities/sororities, and a dominant Division I athletics culture in the Big Ten.",
      "transportation_impact": "Large urban campus in Columbus; students extensively utilize COTA buses, granting easy access to a top midwest metro for internships.",
      "research_impact": "R1 institution with $1.58 billion in R&D expenditures (12th nationally), providing immense undergraduate research opportunities."
    }
  },
