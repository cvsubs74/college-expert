  "strategic_profile": {
    "executive_summary": "Northeastern University is an elite private research institution renowned for its cooperative education (co-op) program, which integrates rigorous academics with full-time professional experience. The university has seen an unprecedented surge in applications, dropping its acceptance rate into the low single digits and driving aggressive global campus expansion.",
    "market_position": "Elite Private",
    "admissions_philosophy": "Holistic",
    "us_news_rank": 46,
    "analyst_takeaways": [
      {
        "category": "Selectivity",
        "insight": "Northeastern has an ED admit rate of ~43% compared to an RD rate of ~3.8%.",
        "implication": "Applicants lacking supplemental essays apply en masse in RD; genuine applicants must use ED to demonstrate commitment and realistically gain admission."
      },
      {
        "category": "Academic",
        "insight": "The co-op program is mandatory for the majority of the student experience, heavily shifting focus to pre-professional outcomes.",
        "implication": "Students looking for a traditional, continuous 4-year campus social life may feel displaced by the constant rotation of peers into the workforce."
      },
      {
        "category": "Financial",
        "insight": "Students do not pay tuition during their 6-month co-op cycles.",
        "implication": "Despite a high sticker price, the lack of tuition during co-ops and the income earned can significantly offset the total cost of attendance."
      }
    ],
    "campus_dynamics": {
      "social_environment": "Highly pre-professional and driven. Social cohesion can be challenging due to students rotating in and out of Boston for co-ops and study abroad programs.",
      "transportation_impact": "Embedded seamlessly into urban Boston, with direct access to the MBTA allowing easy commutes to corporate co-ops downtown.",
      "research_impact": "R1 Doctoral University with extremely high research activity, specifically in health informatics, cybersecurity, and mechanobiology."
    }
  },
