  "strategic_profile": {
    "executive_summary": "The University of St. Thomas is a private Catholic research university grounded in the liberal arts, offering comprehensive undergraduate and graduate programs. As Minnesota's largest private nonprofit university, it emphasizes ethical leadership, social innovation, and community engagement.",
    "market_position": "Mid-size Private Catholic University",
    "admissions_philosophy": "Holistic",
    "us_news_rank": 148,
    "analyst_takeaways": [
      {
        "category": "Selectivity",
        "insight": "The overall acceptance rate hovers around 85%, making it highly accessible for most applicants.",
        "implication": "It serves as a strong target or safety school for many students looking for a comprehensive private university experience."
      },
      {
        "category": "Financial",
        "insight": "100% of first-time, first-year students are offered a St. Thomas scholarship, and 97% of students receive some form of aid.",
        "implication": "Generous institutional discounting significantly offsets the high $54k+ tuition sticker price."
      },
      {
        "category": "Academic",
        "insight": "The Schulze School of Entrepreneurship and the engineering programs are highly regarded nationally.",
        "implication": "It is an excellent option for business, engineering, and innovation-minded students seeking hands-on learning."
      }
    ],
    "campus_dynamics": {
      "social_environment": "The urban 78-acre campus is split by Summit Avenue and features a strong Catholic identity, over 130 student clubs, and NCAA Division I athletics (The Tommies).",
      "transportation_impact": "Proximate to the Twin Cities, offering abundant internships and networking opportunities with local Fortune 500 companies.",
      "research_impact": "Designated as a Changemaker Campus with significant funding in STEAM education and dedicated undergraduate research grants."
    }
  },
