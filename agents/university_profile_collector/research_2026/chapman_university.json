  "strategic_profile": {
    "executive_summary": "Chapman University is a mid-sized, highly-ranked private research institution known for its personalized education and tight-knit community. It blends robust liberal arts offerings with elite pre-professional programs, particularly excelling in film and business.",
    "market_position": "Elite Private / R2 Doctoral University",
    "admissions_philosophy": "Holistic",
    "us_news_rank": 110,
    "analyst_takeaways": [
      {
        "category": "Selectivity",
        "insight": "High reliance on test-optional holistic review, heavily prioritizing high school rigor and creative portfolios for specialized schools.",
        "implication": "Applicants to flagship programs like Dodge College must rely on exceptional creative supplements rather than standard metrics."
      },
      {
        "category": "Financial",
        "insight": "High sticker price is frequently offset by substantial merit scholarships and need-based institutional grants.",
        "implication": "Students with strong academic profiles are highly likely to receive awards such as the Presidential or Dean's scholarships, making COA competitive."
      },
      {
        "category": "Culture",
        "insight": "Suburban, Mediterranean-style campus with close proximity to LA and the beach.",
        "implication": "Ideal for students seeking a small-town collegiate feel with immediate access to major industry hubs in Southern California."
      }
    ],
    "campus_dynamics": {
      "social_environment": "Tight-knit community centered around 'The Orange Circle', with a prominent but non-mandatory Greek life.",
      "transportation_impact": "Highly commutable to Los Angeles, fostering strong entertainment and business internship pipelines.",
      "research_impact": "High research activity (R2) featuring dedicated centers like the Center for Targeted Drug Delivery."
    }
  },
