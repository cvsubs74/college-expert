# Deploy-time env template for payment-manager-v2 (Stratia Admissions).
#
# This file is the COMMITTED source of truth for the function's runtime env.
# It contains NO secrets — the ${...} placeholders are filled at deploy time by
# deploy.sh from Secret Manager (see deploy_payment_manager_v2):
#   STRIPE_SECRET_KEY      <- secret: stratia-stripe-secret-key
#   STRIPE_WEBHOOK_SECRET  <- secret: stratia-stripe-webhook-secret
#
# Both secrets belong to the Stratia Admissions Stripe account
# (acct_1SqNZkIaK5CUG9Yl). deploy.sh renders this into the gitignored
# env.deploy.yaml, deploys with it, then deletes it. Never commit real keys.
#
# NOTE: the old flow read a gitignored env.yaml directly; when that file was
# absent the deploy failed with "Unable to read file [env.yaml]". This template
# removes that fragility — the env is now regenerable from Secret Manager.
FRONTEND_URL: "https://stratiaadmissions.com"
PROFILE_MANAGER_V2_URL: "https://profile-manager-v2-pfnwjfp26a-ue.a.run.app"
STRIPE_SECRET_KEY: "${STRIPE_SECRET_KEY}"
STRIPE_WEBHOOK_SECRET: "${STRIPE_WEBHOOK_SECRET}"
